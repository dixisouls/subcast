#!/usr/bin/env python3
"""Plugin bin/ entry point: adds the plugin's src/ directory to sys.path
and delegates to cli.spawn_agent.main(), so the plugin ships as a single
self-contained script with no separate install step required.
"""

import sys
from pathlib import Path

_SRC_DIR = Path(__file__).resolve().parent.parent / "src"
sys.path.insert(0, str(_SRC_DIR))

from cli.spawn_agent import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
